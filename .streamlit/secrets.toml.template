# Streamlit Secrets 配置文件
# 复制此文件为 secrets.toml 并填入你的API Key

# ═══════════════════════════════════════════
# LLM API 配置（三选一）
# ═══════════════════════════════════════════

# 方案1：Groq（推荐，免费额度，速度快）
LLM_API_KEY = "gsk_your_groq_api_key_here"
LLM_BASE_URL = "https://api.groq.com/openai/v1"
LLM_MODEL = "llama-3.1-70b-versatile"

